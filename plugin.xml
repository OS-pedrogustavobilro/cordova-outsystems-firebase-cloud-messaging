<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<plugin id="com.outsystems.firebase.cloudmessaging" version="2.5.6" xmlns="http://apache.org/cordova/ns/plugins/1.0" xmlns:android="http://schemas.android.com/apk/res/android">

  <name>OSFirebaseCloudMessaging</name>
  <description>Outsystems plugin for Firebase Cloud Messaging</description>
  <author>OutSystems Inc</author>
  <js-module name="OSFirebaseCloudMessaging" src="www/OSFirebaseCloudMessaging.js">
    <clobbers target="cordova.plugins.OSFirebaseCloudMessaging"/>
  </js-module>
  
  <hook type="after_prepare" src="hooks/unzipSound.js" />
  <hook type="after_prepare" src="hooks/cleanUp.js" />

  <platform name="ios">

    <config-file parent="/*" target="config.xml">
      <feature name="OSFirebaseCloudMessaging">
        <param name="ios-package" value="OSFirebaseCloudMessaging"/>
        <param name="onload" value="true" />
      </feature>
      <preference name="SwiftVersion" value="5" />
    </config-file>

    <config-file target="*-Info.plist" parent="UIBackgroundModes">
      <array>
        <string>remote-notification</string>
      </array>
    </config-file>

    <config-file target="*-Debug.plist" parent="aps-environment">
      <string>development</string>
    </config-file>
    <config-file target="*-Release.plist" parent="aps-environment">
      <string>production</string>
    </config-file>

		<!-- iOS Source Files -->
    <source-file src="src/ios/OSFCMEventExtensions.swift" />
    <source-file src="src/ios/OSFirebaseCloudMessaging.swift" />
    <header-file src="src/ios/AppDelegate+OSFirebaseCloudMessaging.h" />
    <source-file src="src/ios/AppDelegate+OSFirebaseCloudMessaging.m" />

    <!-- OSFirebaseMessagingLib Sources -->
    <source-file src="src/ios/ios-lib/CoreDataManager/CoreDataManager.swift" />
    <source-file src="src/ios/ios-lib/CoreDataManager/NotificationsModel.xcdatamodeld" />
    <source-file src="src/ios/ios-lib/Extensions/Date+Extension.swift" />
    <source-file src="src/ios/ios-lib/Extensions/Encodable+Extension.swift" />
    <source-file src="src/ios/ios-lib/Extensions/OSLCNOActionDelegate+Accelerators.swift" />
    <source-file src="src/ios/ios-lib/FirebaseMessagingApplicationDelegate.swift" />
    <source-file src="src/ios/ios-lib/FirebaseMessagingController.swift" />
    <source-file src="src/ios/ios-lib/Managers/MessagingManager.swift" />
    <source-file src="src/ios/ios-lib/Managers/NotificationManager.swift" />
    <source-file src="src/ios/ios-lib/Model/OSFCMExtraData.swift" />
    <source-file src="src/ios/ios-lib/Model/OSFCMNotification.swift" />
    <source-file src="src/ios/ios-lib/Protocols/FirebaseMessagingEventProtocol.swift" />
    <source-file src="src/ios/ios-lib/Protocols/MessagingProtocol.swift" />
    <source-file src="src/ios/ios-lib/Protocols/UNUserNotificationCenterProtocol.swift" />
    <source-file src="src/ios/ios-lib/PushDataMessages/Models/OSFCMPushNotificationModel.swift" />
    <source-file src="src/ios/ios-lib/PushDataMessages/OSFCMPushDataMessageBehaviour.swift" />
    <source-file src="src/ios/ios-lib/PushDataMessages/Protocols/OSFCMPushDataMessage.swift" />
    <source-file src="src/ios/ios-lib/Utils/FirebaseConfigurations.swift" />
    <source-file src="src/ios/ios-lib/Utils/FirebaseMessagingErrors.swift" />
    <source-file src="src/ios/ios-lib/Utils/FirebaseNotificationEventType.swift" />
    <source-file src="src/ios/ios-lib/Utils/OSFCMSubscriptionTopic.swift" />
    <source-file src="src/ios/ios-lib/Utils/OSFCMTokenType.swift" />

    <!-- OSLocalNotificationsLib Sources -->
    <source-file src="src/ios/ios-local-not-lib/Models/OSLCNOAction.swift" />
    <source-file src="src/ios/ios-local-not-lib/Models/OSLCNOActionEvent.swift" />
    <source-file src="src/ios/ios-local-not-lib/Models/OSLCNOActionTextField.swift" />
    <source-file src="src/ios/ios-local-not-lib/Models/OSLCNOActionType.swift" />
    <source-file src="src/ios/ios-local-not-lib/Models/OSLCNOError.swift" />
    <source-file src="src/ios/ios-local-not-lib/Models/OSLCNOInternalEvent.swift" />
    <source-file src="src/ios/ios-local-not-lib/Models/OSLCNOParameter.swift" />
    <source-file src="src/ios/ios-local-not-lib/Models/OSLCNORouteData.swift" />
    <source-file src="src/ios/ios-local-not-lib/OSLCNOFactory.swift" />
    <source-file src="src/ios/ios-local-not-lib/OSLCNOWrapper.swift" />
    <source-file src="src/ios/ios-local-not-lib/Protocols/OSLCNOActionDelegate.swift" />
    <source-file src="src/ios/ios-local-not-lib/Protocols/OSLCNOCenterDelegate.swift" />
    <source-file src="src/ios/ios-local-not-lib/Protocols/OSLCNOContentDelegate.swift" />
    <source-file src="src/ios/ios-local-not-lib/UNExtensions/Extensions/Encodable+UNUserNotificationCenter.swift" />
    <source-file src="src/ios/ios-local-not-lib/UNExtensions/UNMutableNotificationContent+Adapter.swift" />
    <source-file src="src/ios/ios-local-not-lib/UNExtensions/UNNotificationActionExtension.swift" />
    <source-file src="src/ios/ios-local-not-lib/UNExtensions/UNUserNotificationCenter+Adapter.swift" />

    <!-- Hooks -->
    <hook type="after_prepare" src="hooks/ios/iOSCopyPreferences.js" />

    <podspec>
        <config>
            <source url="https://cdn.cocoapods.org/"/>
        </config>
        <pods use-frameworks="true">
            <pod name="FirebaseMessaging" spec="10.29.0" />
        </pods>
    </podspec>

  </platform>

  <platform name="android">

    <hook type="after_prepare" src="hooks/android/androidCopyChannelInfo.js" />
    <config-file parent="/*" target="res/xml/config.xml">
      <feature name="OSFirebaseCloudMessaging">
        <param name="android-package" value="com.outsystems.firebase.cloudmessaging.OSFirebaseCloudMessaging"/>
	      <param name="onload" value="true" />
      </feature>
      <preference name="GradlePluginKotlinEnabled" value="true" />
      <preference name="GradlePluginKotlinCodeStyle" value="official" />
      <preference name="AndroidXEnabled" value="true"/>
    </config-file>

    <config-file parent="/*" target="AndroidManifest.xml">
      <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    </config-file>

    <source-file src="src/android/com/outsystems/firebase/cloudmessaging/OSFCMPermissionEvents.kt" target-dir="app/src/main/kotlin/com/outsystems/firebase/cloudmessaging"/>
    <source-file src="src/android/com/outsystems/firebase/cloudmessaging/OSFirebaseCloudMessaging.kt" target-dir="app/src/main/kotlin/com/outsystems/firebase/cloudmessaging"/>
    <framework src="src/android/com/outsystems/firebase/cloudmessaging/build.gradle" custom="true" type="gradleReference" />

  </platform>
  
</plugin>
